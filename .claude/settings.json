{
  "autocompact_percentage_override": 75,
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "permissions": {
    "deny": [
      "Read(.venv/**)",
      "Read(__pycache__/**)",
      "Read(data/**)",
      "Read(dbt/target/**)",
      "Read(dbt/.venv/**)",
      "Read(*.egg-info/**)",
      "Read(docs/ge_report/**)"
    ]
  }
}
